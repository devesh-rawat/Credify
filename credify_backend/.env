# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017
DATABASE_NAME=credify_db

# JWT Configuration
JWT_SECRET=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Email Configuration (for OTP)
EMAIL_USER=
EMAIL_PASS=
EMAIL_HOST=
EMAIL_PORT=587

# ML Model Paths
ML_MODEL_PATH=ml_models/credit_score_model.pkl
SCALER_PATH=ml_models/scaler.pkl

# LLM Settings (LM Studio or local LLM)
LLM_API_URL=http://localhost:1234

# Gemini Agent Settings
GEMINI_API_KEY=""
GEMINI_MODEL=gemini-2.0-flash
AGENT_TEMPERATURE=0.7
AGENT_MAX_ITERATIONS=10

# Rate Limiting (for Gemini API)
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_PER_DAY=1500